---
import Layout from '../layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';
import { Button } from '../components/ui/button';
---

<Layout title="VOIDED OBFUSCATOR">
  <div class="min-h-screen bg-[#0a001f] text-white overflow-hidden relative font-mono" onclick="startMusic()">
    <audio id="misery" loop volume="0.5">
      <source src="https://files.catbox.moe/0v4p2k.mp3" type="audio/mpeg">
    </audio>

    <div class="fixed inset-0 bg-[radial-gradient(circle_at_center,#6b21a850_0%,transparent_60%)]"></div>

    <nav class="border-b border-purple-900 bg-black/95 backdrop-blur sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-11 h-11 rounded-3xl bg-gradient-to-br from-purple-600 to-fuchsia-600 flex items-center justify-center text-4xl shadow-[0_0_35px_#c026d3]">🌀</div>
          <h1 class="text-4xl font-black tracking-tighter bg-gradient-to-r from-purple-300 to-fuchsia-400 bg-clip-text text-transparent">VOIDED</h1>
        </div>
        <div class="text-purple-400 text-sm">misery.</div>
      </div>
    </nav>

    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="text-center mb-12">
        <h2 class="text-6xl font-black tracking-tighter mb-4 bg-gradient-to-b from-purple-200 to-purple-600 bg-clip-text text-transparent">OBFUSCATOR</h2>
        <p class="text-purple-400">Type or paste code • Works on mobile</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <Card class="bg-[#120824] border-purple-800 shadow-2xl">
          <CardHeader><CardTitle class="text-purple-300">INPUT CODE</CardTitle></CardHeader>
          <CardContent>
            <textarea 
              id="input" 
              rows="14"
              class="w-full bg-black border border-purple-700 focus:border-fuchsia-500 rounded-2xl p-5 font-mono text-purple-100 min-h-[380px] resize-y text-base"
              placeholder="Paste your code here..."></textarea>
          </CardContent>
        </Card>

        <Card class="bg-[#120824] border-purple-800 shadow-2xl">
          <CardHeader>
            <CardTitle class="flex justify-between text-purple-300">
              OBFUSCATED
              <Button onclick="obfuscate()" class="bg-gradient-to-r from-purple-600 to-fuchsia-600 px-8">OBFUSCATE</Button>
            </CardTitle>
          </CardHeader>
          <CardContent>
            <textarea id="output" rows="14" readonly class="w-full bg-black border border-purple-700 rounded-2xl p-5 font-mono text-fuchsia-200 min-h-[380px] resize-y text-base"></textarea>
            <div class="flex gap-4 mt-6">
              <Button onclick="copyOutput()" class="flex-1">📋 Copy</Button>
              <Button onclick="clearAll()" variant="outline" class="flex-1">Clear</Button>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>

    <button onclick="toggleMusic()" class="fixed bottom-8 right-8 px-6 py-4 bg-purple-950 border border-fuchsia-500 rounded-2xl text-3xl hover:scale-110 transition z-50">♪</button>
  </div>

  <script>
    const music = document.getElementById('misery');
    let musicStarted = false;

    function startMusic() {
      if (!musicStarted) {
        music.play().catch(() => {});
        musicStarted = true;
      }
    }

    function toggleMusic() {
      if (music.paused) music.play();
      else music.pause();
    }

    function obfuscate() {
      const input = document.getElementById('input').value.trim();
      if (!input) return alert("Paste code first");
      const obfuscated = input.split('').map(c => Math.random() > 0.6 ? '\\u' + c.charCodeAt(0).toString(16).padStart(4,'0') : c).join('');
      document.getElementById('output').value = obfuscated;
    }

    function copyOutput() {
      const text = document.getElementById('output').value;
      if (text) navigator.clipboard.writeText(text);
      alert("✅ Copied!");
    }

    function clearAll() {
      document.getElementById('input').value = '';
      document.getElementById('output').value = '';
    }

    // Start music on any interaction
    document.addEventListener('touchstart', startMusic, { once: true });
    document.addEventListener('click', startMusic, { once: true });
  </script>
</Layout>
