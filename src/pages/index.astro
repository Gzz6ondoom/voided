---
import Layout from '../layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Badge } from '../components/ui/badge';

const mods = [
  { id: 1, name: "Epic Textures 4K", author: "PixelForge", version: "2.1.0", desc: "Stunning 4K textures for immersive gameplay.", category: "Graphics", downloads: 124890, image: "https://picsum.photos/id/1015/600/300" },
  { id: 2, name: "Smart AI Companions", author: "NeuralMods", version: "1.4.3", desc: "Advanced NPC behavior with dynamic dialogues.", category: "Gameplay", downloads: 67320, image: "https://picsum.photos/id/201/600/300" },
  { id: 3, name: "Ultra Performance", author: "OptiCore", version: "3.0.1", desc: "Massive FPS boost + reduced stuttering.", category: "Performance", downloads: 98210, image: "https://picsum.photos/id/180/600/300" },
  { id: 4, name: "Realistic Weapons", author: "GunMaster", version: "1.9.2", desc: "Highly detailed weapon models and sounds.", category: "Weapons", downloads: 45230, image: "https://picsum.photos/id/237/600/300" },
];
---

<Layout title="Voided Mod Loader">
  <div class="min-h-screen bg-zinc-950 text-white">
    <!-- Top Navigation -->
    <nav class="border-b border-zinc-800 bg-zinc-950 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-gradient-to-br from-violet-600 to-fuchsia-600 rounded-2xl flex items-center justify-center text-2xl font-black">V</div>
          <div>
            <h1 class="text-3xl font-bold tracking-tight">Voided</h1>
            <p class="text-xs text-zinc-500 -mt-1">Mod Loader</p>
          </div>
        </div>

        <div class="flex-1 max-w-md mx-8">
          <Input 
            type="text" 
            placeholder="Search mods, authors, or categories..." 
            class="bg-zinc-900 border-zinc-700 focus:border-violet-500"
          />
        </div>

        <div class="flex items-center gap-6 text-sm">
          <a href="#" class="hover:text-violet-400 transition">Browse</a>
          <a href="#" class="hover:text-violet-400 transition">My Library</a>
          <a href="#" class="hover:text-violet-400 transition">Profiles</a>
          <Button variant="outline" class="border-violet-500 text-violet-400 hover:bg-violet-950">Upload Mod</Button>
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto px-6 py-10">
      <div class="flex justify-between items-end mb-8">
        <div>
          <h2 class="text-4xl font-bold">Discover Mods</h2>
          <p class="text-zinc-400 mt-1">Community favorites • Updated today</p>
        </div>
        <div class="text-sm text-zinc-500">1,284 mods available</div>
      </div>

      <!-- Mod Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mods.map((mod) => (
          <Card class="bg-zinc-900 border-zinc-800 overflow-hidden hover:border-violet-500 group transition-all hover:-translate-y-1">
            <div class="relative">
              <img src={mod.image} class="w-full h-48 object-cover" alt={mod.name} />
              <Badge class="absolute top-3 right-3 bg-black/70 text-white">{mod.category}</Badge>
            </div>

            <CardHeader>
              <CardTitle class="text-xl">{mod.name}</CardTitle>
              <p class="text-sm text-zinc-400">by {mod.author} • v{mod.version}</p>
            </CardHeader>

            <CardContent class="pt-0 pb-6">
              <p class="text-zinc-300 line-clamp-2 text-sm mb-6">{mod.desc}</p>
              
              <div class="flex items-center justify-between">
                <div class="text-xs text-zinc-500">
                  {mod.downloads.toLocaleString()} downloads
                </div>
                <Button 
                  onclick={`installMod(${mod.id}, "${mod.name}")`}
                  class="bg-violet-600 hover:bg-violet-700 px-8"
                >
                  Install
                </Button>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </div>

  <script>
    function installMod(id, name) {
      alert(`🚀 Downloading ${name}... (This is a demo — connect to real download API later)`);
      // You can later replace this with fetch to your backend
    }
  </script>
</Layout>
