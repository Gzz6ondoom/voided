---
import Layout from '../layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Badge } from '../components/ui/badge';

const mods = [ /* same as before */ ];
---

<Layout title="Voided Mod Loader">
  <div class="min-h-screen bg-zinc-950 text-white overflow-hidden relative">
    <!-- Background Music -->
    <audio id="bgMusic" loop autoplay volume="0.3">
      <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
    </audio>

    <!-- Neon Glow Background -->
    <div class="absolute inset-0 bg-[radial-gradient(at_center,#4f46e520_0%,transparent_70%)]"></div>

    <!-- Navigation -->
    <nav class="border-b border-zinc-800/80 bg-zinc-950/90 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-gradient-to-br from-fuchsia-500 via-violet-500 to-cyan-500 rounded-2xl flex items-center justify-center text-3xl font-black shadow-[0_0_20px_#a855f7] animate-pulse">V</div>
          <h1 class="text-3xl font-bold tracking-tighter">VOIDED</h1>
        </div>

        <div class="flex-1 max-w-lg mx-8">
          <Input 
            type="text" 
            placeholder="Search mods..." 
            class="bg-zinc-900/80 border-zinc-700 focus:border-fuchsia-500 focus:ring-fuchsia-500 placeholder:text-zinc-500"
          />
        </div>

        <div class="flex gap-8 text-sm font-medium">
          <a href="#" class="hover:text-fuchsia-400 transition">Browse</a>
          <a href="#" class="hover:text-fuchsia-400 transition">Library</a>
          <a href="#" class="hover:text-fuchsia-400 transition">Community</a>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-12 relative">
      <div class="text-center mb-12">
        <h2 class="text-5xl font-bold tracking-tight bg-gradient-to-r from-fuchsia-400 via-violet-400 to-cyan-400 bg-clip-text text-transparent">
          Mod Loader
        </h2>
        <p class="text-zinc-400 mt-3 text-lg">Glow up your game</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {mods.map(mod => (
          <Card class="group bg-zinc-900/70 border border-zinc-700/80 hover:border-fuchsia-500/50 backdrop-blur overflow-hidden transition-all hover:-translate-y-2 hover:shadow-2xl hover:shadow-fuchsia-500/20">
            <div class="relative">
              <img src={mod.image} class="w-full h-52 object-cover transition-transform group-hover:scale-105" alt={mod.name} />
              <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/90 to-transparent"></div>
              <Badge class="absolute top-4 right-4 bg-black/70 backdrop-blur text-xs border border-white/20">{mod.category}</Badge>
            </div>

            <CardHeader class="pb-3">
              <CardTitle class="text-lg group-hover:text-fuchsia-400 transition">{mod.name}</CardTitle>
              <p class="text-xs text-zinc-500">by {mod.author} • {mod.version}</p>
            </CardHeader>

            <CardContent class="pt-0">
              <p class="text-sm text-zinc-300 line-clamp-3 mb-6">{mod.desc}</p>
              
              <div class="flex items-center justify-between">
                <span class="text-xs text-emerald-400 font-mono">{mod.downloads.toLocaleString()} DLs</span>
                <Button 
                  onclick={`install('${mod.name}')`}
                  class="bg-gradient-to-r from-fuchsia-600 to-violet-600 hover:brightness-110 shadow-lg shadow-fuchsia-500/30 transition-all active:scale-95"
                >
                  Install Mod
                </Button>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </main>

    <!-- Music Toggle -->
    <button 
      onclick="toggleMusic()" 
      class="fixed bottom-6 right-6 bg-zinc-900 border border-zinc-700 hover:border-fuchsia-500 p-3 rounded-full shadow-xl transition"
    >
      🎵
    </button>
  </div>

  <script>
    const music = document.getElementById('bgMusic');
    
    function toggleMusic() {
      if (music.paused) {
        music.play();
      } else {
        music.pause();
      }
    }

    function install(name) {
      alert(`Downloading ${name}... Enjoy the glow! 🔥`);
    }

    // Auto play music (some browsers block it until interaction)
    window.addEventListener('click', () => music.play(), { once: true });
  </script>
</Layout>
